# mcp-server-health-monitor — environment variables
#
# Copy this file to .env and fill in the values you need.
# None of these variables are required; the server works without them.

# ---------------------------------------------------------------------------
# HTTP Transport Authentication (src/auth.ts)
# Only relevant when running with --http-port.
# ---------------------------------------------------------------------------

# API key required in the X-API-Key header for every HTTP request.
# If unset, API-key authentication is disabled.
MCP_API_KEY=your-secret-api-key-here

# Secret used to verify HMAC-SHA256 JWTs in the Authorization: Bearer header.
# If unset, JWT authentication is disabled.
MCP_JWT_SECRET=your-jwt-secret-here

# ---------------------------------------------------------------------------
# System / path helpers (used internally)
# ---------------------------------------------------------------------------

# Home directory used for tilde (~) expansion when writing dashboard output.
# Normally set automatically by the OS; override only if needed.
# HOME=/Users/yourname

# Windows only: base path for AppData when discovering MCP config files.
# Normally set automatically by Windows; override only if needed.
# APPDATA=C:\Users\yourname\AppData\Roaming
