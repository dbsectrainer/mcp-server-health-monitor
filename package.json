{
  "name": "mcp-server-health-monitor",
  "version": "1.0.0",
  "description": "Health monitoring for all your MCP servers",
  "author": "dbsectrainer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dbsectrainer/mcp-server-health-monitor.git"
  },
  "homepage": "https://github.com/dbsectrainer/mcp-server-health-monitor#readme",
  "type": "module",
  "bin": {
    "mcp-server-health-monitor": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "monitoring",
    "health-check"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.0.0",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.0",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0",
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
